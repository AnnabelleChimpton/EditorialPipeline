# --- Config validation ---

REQUIRED_FIELDS = [
    "brand.name", "brand.slug", "brand.id_prefix",
    "voice.personality",
    "domain.zones",
    "slop.hard_fail",
    "schedule.card", "schedule.pre_compute", "schedule.commit",
    "delivery.channel", "delivery.to",
    "agent.model", "agent.agent_id",
]


def get_nested(d, path):
    """Get a nested dict value by dot-separated path."""
    keys = path.split(".")
    for k in keys:
        if not isinstance(d, dict) or k not in d:
            return None
        d = d[k]
    return d


def validate_config(config):
    """Validate brand config. Returns list of error strings."""
    errors = []
    for field in REQUIRED_FIELDS:
        val = get_nested(config, field)
        if val is None:
            errors.append(f"Missing required field: {field}")

    # Validate zone slugs
    zones = get_nested(config, "domain.zones") or []
    for i, z in enumerate(zones):
        if "slug" not in z:
            errors.append(f"domain.zones[{i}] missing 'slug'")
        if "name" not in z:
            errors.append(f"domain.zones[{i}] missing 'name'")

    # Validate slop patterns compile
    for section in ("hard_fail", "warn"):
        patterns = get_nested(config, f"slop.{section}") or []
        for i, p in enumerate(patterns):
            if "pattern" not in p:
                errors.append(f"slop.{section}[{i}] missing 'pattern'")
                continue
            try:
                re.compile(p["pattern"])
            except re.error as e:
                errors.append(f"slop.{section}[{i}] invalid regex: {e}")

    return errors


# --- Template rendering ---

def render_list(items, prefix="- "):
    """Render a list of strings as markdown bullet points."""
    return "\n".join(f"{prefix}{item}" for item in items)


def render_zones(zones):
    """Render zone list for domain-zones.md."""
    parts = []
    for i, z in enumerate(zones, 1):
        section = f"## {i}. `{z['slug']}` — {z['name']}\n\n"
        section += z.get("description", "") + "\n"
        examples = z.get("examples", [])
        if examples:
            section += "\n**Example angles:**\n"
            section += render_list(examples)
        parts.append(section)
    return "\n---\n\n".join(parts)


def render_platform_guidelines(platforms):
    """Render platform guidelines for brand-config.md."""
    parts = []
    for name, cfg in platforms.items():
        section = f"### {name.title()}\n"
        section += f"- {cfg.get('tone', '')}\n"
        if "length" in cfg:
            section += f"- Can be longer ({cfg['length']})\n" if name == "linkedin" else f"- {cfg['length']}\n"
        for note in cfg.get("notes", []):
            section += f"- {note}\n"
        parts.append(section)
    return "\n".join(parts)


def render_domain_cliches(config):
    """Render domain-specific cliches from donts list."""
    donts = get_nested(config, "voice.donts") or []
    # Select the ones that look like domain cliches
    cliches = []
    for d in donts:
        cliches.append(f'- {d}')
    return "\n".join(cliches[:10])  # Top 10


def render_domain_voice_traps(config):
    """Render domain-specific voice traps for post-draft-rubric."""
    donts = get_nested(config, "voice.donts") or []
    traps = get_nested(config, "slop.domain_traps") or []
    lines = []
    for d in donts[:10]:
        lines.append(f"- Use {d} unironically" if not d.startswith('"') else f"- Use {d}")
    for t in traps:
        lines.append(f"- Say {t}")
    # Add standard tech commentary voice traps
    lines.extend([
        '- Use LinkedIn-bro cadence (short sentence. Paragraph break. Another short sentence. Repeat.)',
        '- Stack buzzwords ("AI-powered innovation in the cloud ecosystem")',
    ])
    return "\n".join(lines)


def render_domain_brief_traps(config):
    """Render domain-specific brief traps."""
    name = get_nested(config, "brand.name")
    return (
        f'- Angle is just "Company X did a bad thing" — needs a pattern or thesis beyond the single incident\n'
        f'- Hook opens with "In a move that surprised no one..." or "It was only a matter of time..." — lazy framing\n'
        f'- Brief recommends LinkedIn for every topic — match platform to material, not default\n'
        f'- Brief recommends thread, carousel, or any non-blog format — this brand publishes blog posts only'
    )


def render_domain_qa_cliches(config):
    """Render domain-specific QA cliches."""
    traps = get_nested(config, "slop.domain_traps") or []
    lines = []
    for t in traps:
        lines.append(f"  - {t}")
    return "\n".join(lines) if lines else "  - (see brand-config.md for domain-specific patterns)"


def render_hard_fail_summary(config):
    """Render hard fail pattern summary for QA rubric."""
    patterns = get_nested(config, "slop.hard_fail") or []
    # Group by category
    lines = []
    for p in patterns:
        lines.append(f'- {p["name"]}')
    return "\n".join(lines)


def render_queue_field_rules(config):
    """Render queue field rules for AGENTS.md."""
    zones = get_nested(config, "domain.zones") or []
    zone_slugs = [z["slug"] for z in zones]
    fields = get_nested(config, "pipeline.queue_fields") or []

    lines = []
    for f in fields:
        name = f["name"]
        if f.get("values_from") == "domain.zones":
            lines.append(f'- **`{name}`**: Must be one of the {len(zone_slugs)} slugs from `REFERENCE/domain-zones.md` — pick the single best match:')
            lines.append(f'  `{"`, `".join(zone_slugs)}`')
        elif "values" in f:
            vals = f["values"]
            lines.append(f'- **`{name}`**: One of: {", ".join(f"`{v}`" for v in vals)}')
    return "\n".join(lines)


