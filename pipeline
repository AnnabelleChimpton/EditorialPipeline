         120, agent_id, {}),
    ]

    cron_jobs_file = OPENCLAW_DIR / "cron" / "jobs.json"
    if cron_jobs_file.exists():
        with open(cron_jobs_file) as f:
            cron_data = json.load(f)
        existing_names = {j["name"] for j in cron_data.get("jobs", [])}
    else:
        existing_names = set()

    jobs_created = 0
    for lane, cron_expr, model, name, message, timeout, lane_agent, extra_flags in lane_configs:
        if not cron_expr:
            continue
        if name in existing_names:
            print(f"  Cron job already exists: {name}")
            continue

        cmd = [
            "openclaw", "cron", "add",
            "--name", name,
            "--schedule", cron_expr,
            "--agent", lane_agent,
            "--model", model or agent_config.get("model", "anthropic/claude-sonnet-4-6"),
            "--message", message,
            "--timeout", str(timeout),
            "--delivery-channel", delivery.get("channel", "discord"),
            "--delivery-to", delivery.get("to", ""),
        ]

        # Add extra flags (e.g. --light-context, --thinking none)
        for flag, value in extra_flags.items():
            if value is True:
                cmd.append(flag)
            elif value is not False:
                cmd.extend([flag, str(value)])

        try:
            result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
            if result.returncode == 0:
                print(f"  Created cron job: {name}")
                jobs_created += 1
            else:
                print(f"  WARNING: Failed to create cron job '{name}': {result.stderr.strip()}", file=sys.stderr)
        except FileNotFoundError:
            print(f"  WARNING: 'openclaw' CLI not found — skipping cron job creation for '{name}'", file=sys.stderr)
            break
        except subprocess.TimeoutExpired:
            print(f"  WARNING: Timeout creating cron job '{name}'", file=sys.stderr)

    # 8. Add system crontab entries
    pre_compute_expr = schedule.get("pre_compute", "57 * * * *")
    commit_expr = schedule.get("commit", "2-58/4 * * * *")

    crontab_lines = [
        f"\n# {brand_name} pipeline: pre-compute state",
        f"{pre_compute_expr} cd {workspace} && python3 REFERENCE/pipeline-cron.py >> REFERENCE/.state/cron.log 2>&1",
        f"\n# {brand_name} pipeline: commit staged ops",
        f"{commit_expr} cd {workspace} && python3 REFERENCE/pipeline-commit.py >> REFERENCE/.state/commit.log 2>&1",
    ]

    try:
        result = subprocess.run(["crontab", "-l"], capture_output=True, text=True)
        existing_crontab = result.stdout if result.returncode == 0 else ""
    except FileNotFoundError:
        existing_crontab = ""

    # Check if entries already exist
    marker = f"cd {workspace} && python3 REFERENCE/pipeline-cron.py"
    if marker not in existing_crontab:
        new_crontab = existing_crontab.rstrip() + "\n" + "\n".join(crontab_lines) + "\n"
        try:
            proc = subprocess.run(["crontab", "-"], input=new_crontab, capture_output=True, text=True)
            if proc.returncode == 0:
                print(f"  Added system crontab entries for pre-compute and commit")
            else:
                print(f"  WARNING: Failed to update crontab: {proc.stderr.strip()}", file=sys.stderr)
        except Exception as e:
            print(f"  WARNING: Could not update crontab: {e}", file=sys.stderr)
    else:
        print(f"  System crontab entries already exist")

    # 9. Run pipeline-cron.py once to populate .state/
    try:
        result = subprocess.run(
            [sys.executable, str(ref_dir / "pipeline-cron.py")],
            cwd=str(workspace),
            capture_output=True, text=True, timeout=30
        )
        if result.returncode == 0:
            print(f"  Initial state computed: {result.stdout.strip()}")
        else:
            print(f"  WARNING: Initial state computation failed: {result.stderr.strip()}", file=sys.stderr)
    except Exception as e:
        print(f"  WARNING: Could not run pipeline-cron.py: {e}", file=sys.stderr)

    # 10. Summary
    print(f"\n{'='*60}")
    print(f"Workspace created: {workspace}")
    print(f"Brand: {config['brand']['name']}")
    print(f"Agent: {agent_id}")
    print(f"Zones: {len(config.get('domain', {}).get('zones', []))}")
    print(f"Slop patterns: {len(config.get('slop', {}).get('hard_fail', []))} hard-fail, {len(config.get('slop', {}).get('warn', []))} warn")
    print(f"Cron jobs created: {jobs_created}")
    print(f"{'='*60}")


# --- Sync command ---

def cmd_sync(args):
    slug = args.brand_slug
    workspace = OPENCLAW_DIR / f"workspace-{slug}"

    if not workspace.exists():
        print(f"ERROR: Workspace not found: {workspace}", file=sys.stderr)
        sys.exit(1)

    # Find brand.yaml (follow symlink if needed)
    brand_yaml = workspace / "brand.yaml"
    if not brand_yaml.exists():
        # Try to find it in brands/
        brand_yaml = BRANDS_DIR / f"{slug}.yaml"
        if not brand_yaml.exists():
            print(f"ERROR: brand.yaml not found for '{slug}'", file=sys.stderr)
            sys.exit(1)

    config_path = brand_yaml.resolve()
    with open(config_path) as f:
        config = yaml.safe_load(f)

    errors = validate_config(config)
    if errors:
        print("Config validation errors:", file=sys.stderr)
        for e in errors:
            print(f"  - {e}", file=sys.stderr)
        sys.exit(1)

    variables = build_template_vars(config)
    ref_dir = workspace / "REFERENCE"
    changes = []

    # Re-generate templated files
    template_files = {
        workspace / "AGENTS.md": TEMPLATE_DIR / "agents.md.tmpl",
        ref_dir / "brand-config.md": TEMPLATE_DIR / "brand-config.md.tmpl",
        ref_dir / "domain-zones.md": TEMPLATE_DIR / "domain-zones.md.tmpl",
    }

    rubric_dir = TEMPLATE_DIR / "rubrics"
    if rubric_dir.exists():
        for tmpl in rubric_dir.glob("*.tmpl"):
            out_name = tmpl.name.replace(".tmpl", "")
            template_files[ref_dir / out_name] = tmpl

    # Lane instruction templates
    lane_instr_dir = TEMPLATE_DIR / "lane-instructions"
    lane_instr_out = ref_dir / "lane-instructions"
    lane_instr_out.mkdir(parents=True, exist_ok=True)
    if lane_instr_dir.exists():
        for tmpl in lane_instr_dir.glob("*.tmpl"):
            out_name = tmpl.name.replace(".tmpl", "")
            template_files[lane_instr_out / out_name] = tmpl

    for output, template in template_files.items():
        if not template.exists():
            continue
        new_content = render_template(template, variables)
        if output.exists():
            with open(output) as f:
                old_content = f.read()
            if old_content != new_content:
                with open(output, "w") as f:
                    f.write(new_content)
                changes.append(f"  updated: {output.name}")
            # else: no change
        else:
            with open(output, "w") as f:
                f.write(new_content)
            changes.append(f"  created: {output.name}")

    # Refresh static files if core has newer versions
    if STATIC_DIR.exists():
        for static_file in STATIC_DIR.iterdir():
            if static_file.is_file():
                dest = ref_dir / static_file.name
                if dest.exists():
                    src_mtime = static_file.stat().st_mtime
                    dst_mtime = dest.stat().st_mtime
                    if src_mtime > dst_mtime:
                        shutil.copy2(static_file, dest)
                        changes.append(f"  refreshed: {dest.name}")
                else:
                    shutil.copy2(static_file, dest)
                    changes.append(f"  added: {dest.name}")

    if changes:
        print(f"Synced workspace-{slug}:")
        for c in changes:
            print(c)
    else:
        print(f"workspace-{slug}: already up to date")


# --- List command ---

def cmd_list(args):
    print(f"Pipeline workspaces in {OPENCLAW_DIR}:\n")

    found = False
    for d in sorted(OPENCLAW_DIR.iterdir()):
        if not d.is_dir() or not d.name.startswith("workspace-"):
            continue

        brand_yaml = d / "brand.yaml"
        if not brand_yaml.exists() and not brand_yaml.is_symlink():
            continue

        found = True
        slug = d.name.replace("workspace-", "")

        # Check symlink health
        symlinks_ok = True
        symlink_issues = []
        for name in ["brand.yaml", "REFERENCE/pipeline-tools.py", "REFERENCE/pipeline-cron.py", "REFERENCE/pipeline-commit.py"]:
            p = d / name
            if p.is_symlink():
                if not p.resolve().exists():
                    symlinks_ok = False
                    symlink_issues.append(f"broken: {name}")
            elif not p.exists():
                symlinks_ok = False
                symlink_issues.append(f"missing: {name}")

        # Read brand name
        brand_name = slug
        if brand_yaml.exists():
            try:
                with open(brand_yaml) as f:
                    cfg = yaml.safe_load(f)
                brand_name = cfg.get("brand", {}).get("name", slug)
            except Exception:
                pass

        status = "OK" if symlinks_ok else "ISSUES"
        print(f"  {slug}")
        print(f"    Brand: {brand_name}")
        print(f"    Path:  {d}")
        print(f"    Status: {status}")
        if symlink_issues:
            for issue in symlink_issues:
                print(f"    - {issue}")
        print()

    if not found:
        print("  No pipeline workspaces found.")
        print(f"  Run: pipeline init <brand.yaml>")


# --- Main ---

def main():
    parser = argparse.ArgumentParser(
        description="Config-driven multi-brand research-editorial pipeline",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  pipeline init brands/tech-commentary.yaml
  pipeline init brands/tech-commentary.yaml --dry-run
  pipeline sync tech-commentary
  pipeline list
"""
    )
    sub = parser.add_subparsers(dest="command")

    p_init = sub.add_parser("init", help="Initialize a new pipeline workspace from a brand config")
    p_init.add_argument("brand_yaml", help="Path to brand.yaml config file")
    p_init.add_argument("--dry-run", action="store_true", help="Show what would be created without creating anything")

    p_sync = sub.add_parser("sync", help="Re-generate workspace files from updated brand config")
    p_sync.add_argument("brand_slug", help="Brand slug (e.g., tech-commentary)")

    sub.add_parser("list", help="List all pipeline workspaces and their health")

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        sys.exit(1)

    cmds = {
        "init": cmd_init,
        "sync": cmd_sync,
        "list": cmd_list,
    }
    cmds[args.command](args)


if __name__ == "__main__":
    main()
