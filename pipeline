        "deepdive_beyond_extra": render_deepdive_beyond_extra(config),
    }


def render_template(template_path, variables):
    """Render a template file with variables. Uses str.format_map."""
    with open(template_path, "r") as f:
        content = f.read()
    try:
        return content.format_map(variables)
    except KeyError as e:
        print(f"WARNING: Missing template variable {e} in {template_path}", file=sys.stderr)
        # Fall back to partial rendering
        import string
        t = string.Template(content)
        # Can't use Template for {var} style — just return with missing vars noted
        return content.format_map(SafeDict(variables))


class SafeDict(dict):
    """Dict that returns the key wrapped in braces for missing keys."""
    def __missing__(self, key):
        return f"{{{key}}}"


# --- Init command ---

def cmd_init(args):
    config_path = Path(args.brand_yaml).resolve()
    if not config_path.exists():
        print(f"ERROR: Brand config not found: {config_path}", file=sys.stderr)
        sys.exit(1)

    with open(config_path) as f:
        config = yaml.safe_load(f)

    errors = validate_config(config)
    if errors:
        print("Config validation errors:", file=sys.stderr)
        for e in errors:
            print(f"  - {e}", file=sys.stderr)
        sys.exit(1)

    slug = config["brand"]["slug"]
    workspace = OPENCLAW_DIR / f"workspace-{slug}"
    ref_dir = workspace / "REFERENCE"
    dry_run = args.dry_run

    if dry_run:
        print(f"DRY RUN — would create workspace at: {workspace}")
    else:
        print(f"Creating workspace: {workspace}")

    # Build template variables
    variables = build_template_vars(config)

    # 1. Create workspace directory structure
    dirs_to_create = [
        ref_dir,
        ref_dir / ".state",
        ref_dir / "cards",
        ref_dir / "dossiers",
        ref_dir / "briefs",
        ref_dir / "drafts",
        ref_dir / "qa",
        ref_dir / "revisions",
        ref_dir / "short-form",
        ref_dir / "lane-instructions",
        workspace / "topics",
    ]

    for d in dirs_to_create:
        if dry_run:
            print(f"  mkdir: {d}")
        else:
            d.mkdir(parents=True, exist_ok=True)

    # 2. Create symlinks
    symlinks = {
        workspace / "brand.yaml": config_path,
        ref_dir / "pipeline-tools.py": CORE_DIR / "pipeline-tools.py",
        ref_dir / "pipeline-cron.py": CORE_DIR / "pipeline-cron.py",
        ref_dir / "pipeline-commit.py": CORE_DIR / "pipeline-commit.py",
    }

    for link, target in symlinks.items():
        if dry_run:
            print(f"  symlink: {link} -> {target}")
        else:
            if link.exists() or link.is_symlink():
                link.unlink()
            link.symlink_to(target)

    # 3. Generate markdown files from templates
    template_files = {
        workspace / "AGENTS.md": TEMPLATE_DIR / "agents.md.tmpl",
        ref_dir / "brand-config.md": TEMPLATE_DIR / "brand-config.md.tmpl",
        ref_dir / "domain-zones.md": TEMPLATE_DIR / "domain-zones.md.tmpl",
    }

    # Rubric templates
    rubric_dir = TEMPLATE_DIR / "rubrics"
    if rubric_dir.exists():
        for tmpl in rubric_dir.glob("*.tmpl"):
            out_name = tmpl.name.replace(".tmpl", "")
            template_files[ref_dir / out_name] = tmpl

    # Lane instruction templates
    lane_instr_dir = TEMPLATE_DIR / "lane-instructions"
    if lane_instr_dir.exists():
        for tmpl in lane_instr_dir.glob("*.tmpl"):
            out_name = tmpl.name.replace(".tmpl", "")
            template_files[ref_dir / "lane-instructions" / out_name] = tmpl

    for output, template in template_files.items():
        if not template.exists():
            print(f"  WARNING: template missing: {template}", file=sys.stderr)
            continue
        content = render_template(template, variables)
        if dry_run:
            print(f"  generate: {output} (from {template.name})")
        else:
            with open(output, "w") as f:
                f.write(content)

    # 4. Copy static files
    if STATIC_DIR.exists():
        for static_file in STATIC_DIR.iterdir():
            if static_file.is_file():
                dest = ref_dir / static_file.name
                if dry_run:
                    print(f"  copy: {dest}")
                else:
                    shutil.copy2(static_file, dest)

    # 5. Create empty files
    empty_files = [
        ref_dir / "topic-queue.jsonl",
        ref_dir / "dossier-index.jsonl",
        workspace / "LOG.md",
        workspace / "topics" / "inbox.md",
        ref_dir / ".state" / "stage-append.jsonl",
        ref_dir / ".state" / "stage-status.jsonl",
        ref_dir / ".state" / "stage-queue.jsonl",
    ]

    for ef in empty_files:
        if dry_run:
            print(f"  touch: {ef}")
        else:
            if not ef.exists():
                ef.touch()

    if dry_run:
        print("\nDry run complete. No files were created.")
        return

    # 6. Register agents in openclaw.json (full, web, sonnet-light, haiku-light)
    openclaw_json = OPENCLAW_DIR / "openclaw.json"
    agent_config = config.get("agent", {})
    agent_id = agent_config.get("agent_id", slug)
    agent_id_web = f"{agent_id}-web"
    agent_id_sonnet_light = f"{agent_id}-sonnet-light"
    agent_id_light = f"{agent_id}-light"

    if openclaw_json.exists():
        with open(openclaw_json) as f:
            oc = json.load(f)

        agents = oc.get("agents", {}).get("list", [])
        existing_ids = {a.get("id") for a in agents}

        agent_defs = [
            # Full agent — integrity check (full tool suite)
            (agent_id, {
                "id": agent_id,
                "name": agent_id,
                "workspace": str(workspace),
                "agentDir": str(OPENCLAW_DIR / "agents" / agent_id / "agent"),
